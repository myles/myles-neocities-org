---
type Props = {
  class?: string[];
};
const { class: className } = Astro.props;
---

<main id="ui-container" class:list={[className]}>
  <slot />
</main>

<style>
  @reference "../../styles/global.css";

  #ui-container {
    @apply mx-auto grid max-w-4xl grid-cols-1 gap-8 px-4 py-8;
    @apply md:grid-cols-2;
  }
</style>
