---
import "@fontsource-variable/playwrite-ca";
import "@fontsource/alice";
import AboutMe from "../components/AboutMe.astro";
import Buttons from "../components/Buttons.astro";
import Elsewhere from "../components/Elsewhere.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Milo from "../components/Milo.astro";
import ProfilePhoto from "../components/ProfilePhoto.astro";
import Container from "../components/ui/Container.astro";
import "../styles/global.css";

const SITE_TITLE = "MYLES @ NEOCITIES";
const SITE_DESCRIPTION = "Myles' personal website, hosted on Neocities.";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://myles.neocities.org/#WebSite",
      name: SITE_TITLE,
      description: SITE_DESCRIPTION,
      url: "https://myles.neocities.org",
      publisher: { "@id": "https://myles.garden/#Person" },
      isPartOf: { "@id": "https://neocities.org/#WebSite" },
    },
    {
      "@type": "WebPage",
      "@id": "https://myles.neocities.org/#WebPage",
      name: SITE_TITLE,
      description: SITE_DESCRIPTION,
      url: "https://myles.neocities.org",
      inLanguage: "en-CA",
      isPartOf: { "@id": "https://myles.neocities.org/#WebSite" },
    },
    {
      "@type": "Person",
      "@id": "https://myles.garden/#Person",
      name: "Myles Braithwaite",
      url: "https://myles.garden",
    },
    {
      "@type": "WebSite",
      "@id": "https://neocities.org/#WebSite",
      name: "Neocities",
      url: "https://neocities.org",
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link href="https://proven.lol/9221ca" />

    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{SITE_TITLE}</title>
    <meta name="description" content={SITE_DESCRIPTION} />

    <meta name="theme-color" content="#000080" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
      is:inline
    />
  </head>
  <body id="myles-neocities-org">
    <Container>
      <Header
        class:list={["col-span-3 -order-1", "md:col-span-2 md:order-0"]}
      />
      <ProfilePhoto
        class:list={["col-span-1 -order-2", "md:col-span-2 md:order-0"]}
      />

      <AboutMe class:list={["col-span-full", "md:col-span-2"]} />
      <Elsewhere class:list={["col-span-full", "md:col-span-2"]} />
      <Milo class:list={["col-span-full", "md:col-span-2"]} />

      <Footer class:list={["col-span-full", "md:col-span-2"]} />

      <Buttons class:list={["col-span-full"]} />
    </Container>
  </body>
</html>

<style>
  @reference "../styles/global.css";

  #myles-neocities-org {
    @apply min-h-screen;
    @apply bg-primary;
    @apply bg-[radial-gradient(circle_at_20%_30%,#ffffff_1px,transparent_2px),radial-gradient(circle_at_70%_80%,#ffffff_1px,transparent_2px),radial-gradient(circle_at_40%_60%,#ffff00_1px,transparent_2px),radial-gradient(circle_at_90%_10%,#ffffff_1px,transparent_2px),radial-gradient(circle_at_10%_90%,#ffff00_1px,transparent_2px)];
    @apply bg-size-[80px_80px,120px_120px,100px_100px,60px_60px,140px_140px,auto];
  }
</style>
